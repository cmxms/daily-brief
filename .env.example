# Copy to ".env" for LOCAL runs (never commit the real .env).
# In GitHub Actions these same names are set as repo Secrets, not from this file.

# --- Required: the writer ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Required: live market data (free Tradier brokerage account, market-data only) ---
TRADIER_API_KEY=...

# --- Optional but recommended: overnight headlines ---
FINNHUB_API_KEY=...

# --- Required only when POSTING (run.py --post) ---
# python-substack logs into your Substack account and creates a DRAFT.
SUBSTACK_PUBLICATION_URL=https://yourname.substack.com
SUBSTACK_EMAIL=you@example.com
SUBSTACK_PASSWORD=your-substack-password

# --- Optional knobs (sensible defaults baked in) ---
# BRIEF_MODEL=claude-opus-4-8        # the writer model; sonnet/haiku are cheaper
