# Copy to ".env" for LOCAL runs (never commit the real .env).
# In GitHub Actions these same names are set as repo Secrets, not from this file.

# --- Required: the writer ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Required: live market data (free Tradier brokerage account, market-data only) ---
TRADIER_API_KEY=...

# --- Optional but recommended: overnight headlines ---
FINNHUB_API_KEY=...

# --- Required for Discord posting (run.py --discord) — the cloud / vacation path ---
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> pick a channel -> Copy URL.
# The brief fans out to EVERY webhook configured below (post to multiple servers, e.g. a friend's).
# A failed/expired webhook is skipped, not fatal — your own feed still posts.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
# Optional: extra servers. Either put several URLs comma-separated in DISCORD_WEBHOOK_URL above,
# OR keep them here (one secret per destination is cleaner). Comma/space/newline separated.
# DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/FRIEND_ID/FRIEND_TOKEN

# --- Required only for the Substack path (run.py --post) — LOCAL only (Cloudflare blocks cloud) ---
# python-substack logs into your Substack account and creates a DRAFT.
SUBSTACK_PUBLICATION_URL=https://yourname.substack.com
SUBSTACK_EMAIL=you@example.com
SUBSTACK_PASSWORD=your-substack-password

# --- Optional knobs (sensible defaults baked in) ---
# BRIEF_MODEL=claude-opus-4-8        # the writer model; sonnet/haiku are cheaper
